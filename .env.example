# 사과정원 환경변수 예시
# 실제 값은 .env.local 에 넣어주세요 (.env.local 은 절대 git 에 올라가지 않습니다)

# Supabase 프로젝트 URL (예: https://xxxxxxx.supabase.co)
# 위치: 기존 themonster.kr 의 Supabase 대시보드 → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key
# 위치: 같은 페이지 → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key (서버 전용, RLS 우회)
# 위치: 같은 페이지 → Project API keys → service_role  (⚠️ 절대 외부 노출 금지)
# - 서버 컴포넌트/Server Action 에서 학생 추가/포인트 적립 등 "쓰기" 작업에 사용
# - NEXT_PUBLIC_ 접두사를 절대 붙이지 마세요
SUPABASE_SERVICE_ROLE_KEY=

# 원장 admin 비밀번호 (예: garden2026)
# /admin?key=XXXX 형태로 접근할 때 사용
ADMIN_KEY=garden2026
NEXT_PUBLIC_ADMIN_KEY=garden2026

# 학생 자체 인증용 JWT 시크릿 (서버 전용)
# - monster-site 가 학생 로그인 시 발급하는 'monster_student' 쿠키를 검증할 때 사용
# - middleware.ts (/tree/me/** 보호) 와 src/lib/student-jwt.ts 에서 참조
# - ⚠️ monster-site 의 JWT_SECRET 과 반드시 동일한 값을 사용해야 함
# - NEXT_PUBLIC_ 접두사를 절대 붙이지 마세요
JWT_SECRET=

# Anthropic API key — /admin/quiz-center 의 AI 문제 대량 생성에 사용 (서버 전용)
# 위치: https://console.anthropic.com → Settings → API Keys
# - 형식: sk-ant-api03-XXXX...
# - NEXT_PUBLIC_ 접두사를 절대 붙이지 마세요
ANTHROPIC_API_KEY=

# 웹 푸시(미수령 포인트 알림) VAPID 키 — 3개 모두 설정해야 기능이 켜짐
# 생성: 터미널에서 `npx web-push generate-vapid-keys` 실행
# - Public Key → VAPID_PUBLIC_KEY 와 NEXT_PUBLIC_VAPID_PUBLIC_KEY 에 같은 값
# - Private Key → VAPID_PRIVATE_KEY (서버 전용, 외부 노출 금지)
# 미설정 시: 학생 화면의 "알림 켜기" 버튼이 숨겨지고 발송도 비활성화됨
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# (선택) 매일 19:00 KST 자동 알림 발송용 Vercel Cron 비밀키
# 아무 긴 랜덤 문자열이나 가능 — 설정하면 vercel.json 의 cron 이 활성 동작
CRON_SECRET=
